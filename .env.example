# ============================================
# WhatsApp AI Chat Intelligence Agent - Config
# ============================================

# --- AI Providers (at least one required) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- Default Model Settings ---
DEFAULT_MODEL_PROVIDER=anthropic        # anthropic | openai
DEFAULT_ANTHROPIC_MODEL=claude-sonnet-4-20250514
DEFAULT_OPENAI_MODEL=gpt-4o

# --- Weaviate Vector Database ---
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=                       # leave empty for local Docker

# --- RAG Settings ---
CHUNK_SIZE=50                           # messages per chunk
CHUNK_OVERLAP=10                        # overlap between chunks
MAX_RETRIEVED_CHUNKS=8                  # chunks retrieved per query
EMBEDDING_MODEL=text-embedding-3-small  # OpenAI embedding model

# --- App Settings ---
MAX_FILE_SIZE_MB=50
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=INFO
